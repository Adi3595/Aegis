# Environment
ENVIRONMENT=development
PROJECT_NAME="AEGIS AI Backend"
VERSION="0.1.0"
DEBUG=True

# Security
SECRET_KEY="replace_me_with_a_secure_random_string_in_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
# Default Postgres connection (useful for docker-compose)
DATABASE_URL="postgresql://user:password@localhost:5432/aegis"

# Redis
# Default Redis connection
REDIS_URL="redis://localhost:6379/0"

# CORS
# Comma separated list of origins
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

# External APIs
GROQ_API_KEY=""
