# Core Settings
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://api.aegis.com
NEXT_PUBLIC_WS_URL=wss://api.aegis.com

# Backend Settings
REDIS_URL=redis://redis.internal:6379/0
DATABASE_URL=postgresql+asyncpg://user:pass@db.internal:5432/aegis
CORS_ORIGINS=https://aegis.com,https://www.aegis.com

# Security & Limits
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=150

# Providers
MONITORING_PROVIDER=console # Or 'azure'
SECRET_PROVIDER=env # Or 'keyvault'

# AI Provider
AZURE_OPENAI_ENDPOINT=https://aegis-ai.openai.azure.com/
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4
