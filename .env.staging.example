# Core Settings
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://api.staging.aegis.com
NEXT_PUBLIC_WS_URL=wss://api.staging.aegis.com

# Backend Settings
REDIS_URL=redis://redis.internal:6379/0
DATABASE_URL=postgresql+asyncpg://user:pass@db.internal:5432/aegis
CORS_ORIGINS=https://staging.aegis.com

# Security & Limits
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=300 # More lenient for staging tests

# Providers
MONITORING_PROVIDER=console 
SECRET_PROVIDER=env 

# AI Provider
AZURE_OPENAI_ENDPOINT=https://aegis-ai.openai.azure.com/
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4
